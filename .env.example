# ============================================
# BACKEND - Server Configuration
# ============================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# BACKEND - PostgreSQL Database (Direct Connection)
# Para produção na Vercel, use conexão direta (sem SSH)
# ============================================
USE_SSH_TUNNEL=false
DB_HOST=seu-host.postgres.com
DB_PORT=5432
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_super_segura

# ============================================
# BACKEND - SSH Tunnel (Development Only)
# Usado apenas em ambiente local
# NÃO funciona em serverless (Vercel)
# ============================================
# USE_SSH_TUNNEL=true
# SSH_HOST=seu-servidor-ssh.com
# SSH_PORT=22
# SSH_USER=seu_usuario_ssh
# SSH_PASSWORD=sua_senha_ssh
# SSH_PRIVATE_KEY_PATH=/path/to/private/key
# SSH_PASSPHRASE=passphrase_da_chave
# DB_HOST_REMOTE=127.0.0.1
# DB_PORT_REMOTE=5432

# ============================================
# FRONTEND - API Configuration
# ============================================
VITE_API_URL=http://localhost:3001/api

# ============================================
# VERCEL - Environment Variables
# Configure estas variáveis no dashboard da Vercel:
# 1. Settings > Environment Variables
# 2. Add:
#    - VITE_API_URL (production): https://seu-backend.com/api
#    - DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD
#    - USE_SSH_TUNNEL=false
# ============================================
