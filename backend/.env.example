# Backend Environment Variables
# Copy this file to .env and fill with your actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# FRONTEND URL (for CORS)
# ============================================
# Development
FRONTEND_URL=http://localhost:5173

# Production (uncomment and update when deploying)
# FRONTEND_URL=https://upgrade-kpis.vercel.app

# ============================================
# POSTGRESQL DATABASE (Direct Connection)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kpis_production
DB_USER=admin
DB_PASSWORD=your_secure_password_here

# ============================================
# SSH TUNNEL CONFIGURATION (Development Only)
# ⚠️ WARNING: Set USE_SSH_TUNNEL=false for production!
# Vercel, Railway, and other serverless platforms DO NOT support SSH tunnels.
# ============================================
USE_SSH_TUNNEL=true

# SSH Configuration (only if USE_SSH_TUNNEL=true)
SSH_HOST=your-vps-ip.com
SSH_PORT=22
SSH_USER=root
SSH_PRIVATE_KEY_PATH=/path/to/your/private/key

# SSH Tunnel Forwarding (only if USE_SSH_TUNNEL=true)
SSH_FORWARD_PORT=5432
SSH_FORWARD_HOST=localhost

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to Vercel/Railway/Render:
# 1. Set USE_SSH_TUNNEL=false
# 2. Update DB_HOST to your cloud PostgreSQL URL
# 3. Ensure DB connection uses SSL (add ?sslmode=require if needed)
# 4. Update FRONTEND_URL to your Vercel deployment URL
# 5. Never commit this .env file to Git!

# ============================================
# DATABASE CONNECTION EXAMPLES
# ============================================

# Example 1: Neon.tech
# DB_HOST=ep-cool-darkness-123456.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=your_user
# DB_PASSWORD=your_password
# USE_SSH_TUNNEL=false

# Example 2: Railway PostgreSQL
# DB_HOST=containers-us-west-123.railway.app
# DB_PORT=5432
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=railway_password
# USE_SSH_TUNNEL=false

# Example 3: Supabase
# DB_HOST=db.your-project.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_supabase_password
# USE_SSH_TUNNEL=false

# Example 4: Local Development with SSH Tunnel (current setup)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kpis_production
# DB_USER=admin
# DB_PASSWORD=your_password
# USE_SSH_TUNNEL=true
# SSH_HOST=your-vps.com
# SSH_PORT=22
# SSH_USER=root
# SSH_PRIVATE_KEY_PATH=/path/to/key
