# Frontend Environment Variables
# Copy this file to .env and fill with your actual values

# ============================================
# API CONFIGURATION
# ============================================

# Development (Backend local)
VITE_API_URL=http://localhost:3001/api

# Production (uncomment and update when deploying to Vercel)
# VITE_API_URL=https://seu-backend.railway.app/api

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to Vercel:
# 1. Update VITE_API_URL to your production backend URL
# 2. Configure this variable in Vercel Dashboard:
#    - Go to: Settings > Environment Variables
#    - Add: VITE_API_URL = https://your-backend-url.com/api
#    - Apply to: Production
# 3. Never commit the .env file to Git!

# ============================================
# NOTES
# ============================================
# - All Vite environment variables MUST start with VITE_
# - They are embedded at build time (not runtime)
# - Changing .env after build requires rebuild
# - Access in code via: import.meta.env.VITE_API_URL
